# Copie para `.env.development` ou `.env.production` e ajuste os valores.
# O Nest carrega `.env` e depois `.env.${NODE_ENV}`; para a mesma chave, o valor em `.env` ganha (útil para segredos no servidor).

NODE_ENV=development

# true = registo ativa conta sem email (apenas desenvolvimento)
# AUTH_DEBUG_SKIP_EMAIL_VERIFICATION=false

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=syncyou

# TypeORM: criar/alterar tabelas automaticamente (entidades). Em desenvolvimento já está ativo.
# Defina true se usar NODE_ENV=production mas quiser sync sem migrations (staging / deploy simples).
# DATABASE_SYNCHRONIZE=false

# SMTP (e-mail) — templates Handlebars em src/templates/email/
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=SyncYou

# --- URLs públicas (sem barra no fim) — ver src/config/resolve-public-urls.ts ---
# UI Next / Tauri (OAuth no browser, lista de redirects por defeito, CORS se CORS_ORIGIN vazio).
WEB_APP_ORIGIN=http://localhost:3000
# Onde o cliente alcança ESTE API (ficheiros /api/v1/files, callbacks OAuth, URLs no manifest do updater).
API_PUBLIC_ORIGIN=http://localhost:3001
# Compatibilidade (opcional): API_PUBLIC_BASE_URL ou APP_BASE_URL antigo = mesmo papel que API_PUBLIC_ORIGIN.

# CORS: vazio ou * = origin * sem credentials. Lista separada por vírgulas = origins explícitos + credentials.
# Com lista explícita, WEB_APP_ORIGIN é sempre incluído; usa CORS_EXTRA_ORIGINS para localhost contra API remota.
# CORS_ORIGIN=http://localhost:3000
# CORS_EXTRA_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Deep link Tauri após confirmar e-mail
APP_DEEP_LINK_SCHEME=syncyou
APP_DEEP_LINK_PATH_EMAIL_CONFIRM=auth/email-verified

# Updater desktop (POST publish). Token = mesmo valor que frontend/scripts/tauri-release.sh
DESKTOP_UPDATES_PUBLISH_TOKEN=

# OAuth — redirect no browser (opcional; por defeito WEB_APP_ORIGIN/oauth/callback)
# OAUTH_FRONTEND_REDIRECT_URL=http://localhost:3000/oauth/callback
# Callbacks Google/Microsoft derivam de API_PUBLIC_ORIGIN; só defina se precisar de URL não standard:
# OAUTH_GOOGLE_CALLBACK_URL=https://api.exemplo.com/api/v1/auth/google/callback
# OAUTH_MICROSOFT_CALLBACK_URL=https://api.exemplo.com/api/v1/auth/microsoft/callback
# Lista extra de redirect_uri permitidos (vírgulas)
# OAUTH_FRONTEND_REDIRECT_ALLOWLIST=https://app.exemplo.com/oauth/callback
# Google
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# Microsoft (Azure AD)
# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=

# JWT (RS256) — chaves RSA em data/jwt-keys/
# JWT_KEYS_DIR=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_PASSWORD_RESET_EXPIRES_IN=15m
JWT_ISSUER=syncyou

# OTP (redefinição de senha) — altere em produção
OTP_PEPPER=change-me-in-production

# Mediasoup SFU (chamadas 1:1) — activo por defeito no código. Desligar: MEDIASOUP_ENABLED=false
# MEDIASOUP_ANNOUNCED_IP=203.0.113.10
# MEDIASOUP_RTC_MIN_PORT=40000
# MEDIASOUP_RTC_MAX_PORT=49999
# MEDIASOUP_LOG_LEVEL=warn
