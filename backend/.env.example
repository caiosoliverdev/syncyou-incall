# Copie para `.env.development` ou `.env.production` e ajuste os valores.
# O Nest carrega `.env.${NODE_ENV}` (ver scripts em package.json).

NODE_ENV=development

# true = registo ativa conta sem email (apenas desenvolvimento)
# AUTH_DEBUG_SKIP_EMAIL_VERIFICATION=false

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=syncyou

# TypeORM: criar/alterar tabelas automaticamente (entidades). Em desenvolvimento já está ativo.
# Defina true se usar NODE_ENV=production mas quiser sync sem migrations (staging / deploy simples).
# DATABASE_SYNCHRONIZE=false

# SMTP (e-mail) — templates Handlebars em src/templates/email/
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=SyncYou

# App (URLs públicas e deep link Tauri)
APP_BASE_URL=http://localhost:3000

# Updater Tauri: manifest dinâmico GET /api/v1/desktop-updates/latest.json
# Binários: data/desktop-updates/bundles/ → GET /api/v1/desktop-updates/files/...
# URL pública para montar URLs no manifest (sem barra final):
API_PUBLIC_BASE_URL=http://localhost:3001
# Token para POST /api/v1/desktop-updates/publish (Bearer ou header X-Desktop-Updates-Token).
# O mesmo valor está em frontend/scripts/tauri-release.sh (bloco no início do ficheiro).
# Exemplo só para dev local (não use em produção):
# DESKTOP_UPDATES_PUBLISH_TOKEN=syncyou-local-desktop-publish-dev
DESKTOP_UPDATES_PUBLISH_TOKEN=
APP_DEEP_LINK_SCHEME=syncyou
APP_DEEP_LINK_PATH_EMAIL_CONFIRM=auth/email-verified

# JWT (RS256) — chaves RSA em data/jwt-keys/
# JWT_KEYS_DIR=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_PASSWORD_RESET_EXPIRES_IN=15m
JWT_ISSUER=syncyou

# OTP (redefinição de senha) — altere em produção
OTP_PEPPER=change-me-in-production

# CORS (origens separadas por vírgula; deixe vazio para refletir em dev)
# CORS_ORIGIN=http://localhost:3000

# Mediasoup SFU (chamadas 1:1) — activo por defeito no código. Desligar: MEDIASOUP_ENABLED=false
# Em produção atrás de NAT, defina o IP/hostname que os clientes usam para alcançar o servidor:
# MEDIASOUP_ANNOUNCED_IP=203.0.113.10
# MEDIASOUP_RTC_MIN_PORT=40000
# MEDIASOUP_RTC_MAX_PORT=49999
# MEDIASOUP_LOG_LEVEL=warn

# OAuth — redirect após Google/Microsoft (padrão se não for passado redirect_uri)
# OAUTH_FRONTEND_REDIRECT_URL=http://localhost:3000/oauth/callback
# Lista extra de redirects permitidos (vírgulas), ex.: deep link Tauri syncyou://oauth/callback
# já incluída por defeito no código; use isto para domínios de produção.
# OAUTH_FRONTEND_REDIRECT_ALLOWLIST=https://app.exemplo.com/oauth/callback
# Google
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
# Microsoft (Azure AD)
# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=
# OAUTH_MICROSOFT_CALLBACK_URL=http://localhost:3001/api/v1/auth/microsoft/callback
