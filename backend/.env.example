# =============================================================================
# SyncYou — Nest API (exemplo)
# =============================================================================
# Copia para .env.development ou .env.production e preenche os valores.
# Não commits ficheiros .env com segredos.
#
# Carregamento: ConfigModule usa envFilePath [ '.env', `.env.${NODE_ENV}` ].
# Documentação de URLs: src/config/resolve-public-urls.ts
# =============================================================================

NODE_ENV=development

PORT=3001

AUTH_DEBUG_SKIP_EMAIL_VERIFICATION=true

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=REPLACE_DB_USER
DATABASE_PASSWORD=REPLACE_DB_PASSWORD
DATABASE_NAME=syncyou

DATABASE_SYNCHRONIZE=true

# -----------------------------------------------------------------------------
# SMTP
# -----------------------------------------------------------------------------
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=dev@localhost
MAIL_FROM_NAME=SyncYou

# -----------------------------------------------------------------------------
# URLs públicas (sem barra no fim)
# -----------------------------------------------------------------------------
API_PUBLIC_ORIGIN=http://localhost:3001
WEB_APP_ORIGIN=http://localhost:3000

CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# CORS_EXTRA_ORIGINS=

APP_DEEP_LINK_SCHEME=syncyou
APP_DEEP_LINK_PATH_EMAIL_CONFIRM=auth/email-verified

# -----------------------------------------------------------------------------
# Updater Tauri (POST /api/v1/desktop-updates/publish)
# -----------------------------------------------------------------------------
DESKTOP_UPDATES_PUBLISH_TOKEN=REPLACE_LONG_RANDOM_TOKEN

# -----------------------------------------------------------------------------
# JWT (RS256)
# -----------------------------------------------------------------------------
# JWT_KEYS_DIR=/var/lib/syncyou/jwt-keys
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
JWT_PASSWORD_RESET_EXPIRES_IN=15m
JWT_ISSUER=syncyou

# -----------------------------------------------------------------------------
# OTP (redefinição de senha)
# -----------------------------------------------------------------------------
OTP_PEPPER=REPLACE_STRONG_RANDOM_SECRET

# -----------------------------------------------------------------------------
# Mediasoup (opcional)
# -----------------------------------------------------------------------------
# MEDIASOUP_ENABLED=true
# MEDIASOUP_ANNOUNCED_IP=REPLACE_PUBLIC_IP_OR_HOSTNAME
# MEDIASOUP_RTC_MIN_PORT=40000
# MEDIASOUP_RTC_MAX_PORT=49999
# MEDIASOUP_LOG_LEVEL=warn

# -----------------------------------------------------------------------------
# Export estático Next (opcional, produção / monólito)
# -----------------------------------------------------------------------------
# FRONTEND_STATIC_DIR=/var/www/syncyou/out
