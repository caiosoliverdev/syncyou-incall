{
  "name": "frontend",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run components/platform/video-call-layout/layout-resolvers.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:release": "bash scripts/tauri-release.sh",
    "tauri:latest-json": "bash scripts/generate-latest-json-only.sh",
    "tauri:icons": "cp public/AppIcon1024.png src-tauri/icons/icon.source.png && tauri icon public/AppIcon1024.png -o src-tauri/icons && { test ! -f public/AppIcon.icns || cp -f public/AppIcon.icns src-tauri/icons/icon.icns; }",
    "tauri:icons:legacy": "python3 scripts/generate-app-icon.py && tauri icon src-tauri/icons/icon.png -o src-tauri/icons",
    "tauri:publish": "TAURI_RELEASE_INTERACTIVE=1 npm run tauri:release"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "emoji-picker-react": "^4.18.0",
    "lucide-react": "^1.7.0",
    "mediasoup-client": "^3.18.7",
    "next": "16.2.1",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-icons": "^5.6.0",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.2.2",
    "use-stick-to-bottom": "^1.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
